# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local — it is in .gitignore

# OpenRouter API (get key at openrouter.ai)
ANTHROPIC_AUTH_TOKEN=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_MODEL=deepseek/deepseek-v4-flash:free

# NextAuth (generate secret: openssl rand -base64 32)
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:4000

# Database
# Dev:  DATABASE_URL="file:./dev.db"
# Prod: DATABASE_URL="postgresql://user:password@host/dbname"
DATABASE_URL="file:./dev.db"

# App name
NEXT_PUBLIC_APP_NAME="GA Real Estate Academy"

# LiveKit (optional — for Study Group voice/video)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=
NEXT_PUBLIC_LIVEKIT_URL=
