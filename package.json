{
  "name": "ga-realstate-playground",
  "version": "1.0.0",
  "description": "GA Real Estate Certification Simulator — AI-powered exam prep platform for Georgia Real Estate license candidates",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "prisma generate && next build",
    "start": "next start -p 4000",
    "lint": "next lint",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:reset": "npm run db:push && npm run db:seed",
    "setup": "npm install && npm run db:push && npm run db:seed",
    "type-check": "tsc --noEmit",
    "electron:dev": "wait-on http://localhost:4000 && cross-env NODE_ENV=development electron .",
    "electron:start": "concurrently --kill-other \"npm run dev\" \"npm run electron:dev\"",
    "electron:build:win": "npm run build && electron-builder --win --config electron-builder.yml"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@auth/prisma-adapter": "^2.4.1",
    "@livekit/components-react": "^2.9.21",
    "@prisma/client": "^5.17.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@tanstack/react-query": "^5.51.21",
    "@tanstack/react-virtual": "^3.13.24",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.3.21",
    "immer": "^11.1.8",
    "jsonwebtoken": "^9.0.2",
    "livekit-client": "^2.19.0",
    "livekit-server-sdk": "^2.15.3",
    "lucide-react": "^0.414.0",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^10.1.0",
    "recharts": "^2.12.7",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.4.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/d3": "^7.4.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.4",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.41",
    "prisma": "^5.17.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "wait-on": "^7.2.0"
  }
}
