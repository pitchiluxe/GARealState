// GA Real Estate Certification Simulator — Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  role              String    @default("STUDENT")  // STUDENT | INSTRUCTOR | ADMIN
  department        String?
  agentId           String?   @unique
  isActive          Boolean   @default(true)
  lastSeen          DateTime?
  preferredLanguage String    @default("en")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  practiceTests      PracticeTest[]
  aiSessions         AISession[]
  trainingSessions   TrainingSession[]
  kbArticles         KBArticle[]
  qaScores           QAScore[]
  classroomProgress  ClassroomProgress[]
  certificates       ClassroomCertificate[]
  badges             ClassroomBadge[]
  notifications      Notification[]
  breakroomMessages  BreakroomMessage[]
  breakroomPresence  BreakroomPresence?
  breakroomReactions BreakroomReaction[]
  breakroomUnreads   BreakroomUnread[]
  obsidianNotes      ObsidianNote[]
  tokens             Int                  @default(0)
  tokenTransactions  TokenTransaction[]
  userPresence       UserPresence?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Practice Tests ───────────────────────────────────────────────────────────

model PracticeTest {
  id               String    @id @default(cuid())
  testNumber       String    @unique
  status           String    @default("OPEN")       // OPEN | IN_PROGRESS | COMPLETED | ABANDONED
  priority         String    @default("MEDIUM")     // LOW | MEDIUM | HIGH | CRITICAL
  category         String    // LICENSE_LAW | CONTRACTS | AGENCY | FINANCE | PROPERTY | VALUATION | FAIR_HOUSING | CLOSING | OTHER
  subcategory      String?
  subject          String
  description      String
  resolution       String?
  studentName      String?
  examVersion      String?   // SALESPERSON | BROKER | CAM
  score            Int?
  passingScore     Int       @default(70)
  timeSpent        Int?      // seconds
  firstAttempt     Boolean   @default(true)
  difficulty       String?   // BEGINNER | INTERMEDIATE | ADVANCED
  notes            String?
  aiSummary        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  studentId   String
  student     User              @relation(fields: [studentId], references: [id])
  aiSession   AISession?
  qaScore     QAScore?
  activities  PracticeActivity[]
  tags        PracticeTag[]

  @@index([status])
  @@index([studentId])
  @@index([category])
  @@index([createdAt])
  @@map("practice_tests")
}

model PracticeActivity {
  id        String   @id @default(cuid())
  testId    String
  type      String   // NOTE | STATUS_CHANGE | SCORE | AI_SUGGESTION | REVIEW
  content   String
  metadata  String?
  createdAt DateTime @default(now())

  test PracticeTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("practice_activities")
}

model PracticeTag {
  id     String @id @default(cuid())
  testId String
  tag    String

  test PracticeTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, tag])
  @@map("practice_tags")
}

// ─── AI Sessions ─────────────────────────────────────────────────────────────

model AISession {
  id           String   @id @default(cuid())
  studentId    String
  testId       String?  @unique
  sessionType  String   @default("COPILOT") // COPILOT | TRAINING | SEARCH
  issueInput   String
  aiResponse   String
  tokensUsed   Int?
  latencyMs    Int?
  modelVersion String?
  feedback     String?
  feedbackNote String?
  createdAt    DateTime @default(now())

  student User         @relation(fields: [studentId], references: [id])
  test    PracticeTest? @relation(fields: [testId], references: [id])

  @@index([studentId])
  @@map("ai_sessions")
}

// ─── Knowledge Base ───────────────────────────────────────────────────────────

model KBArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String
  content     String
  category    String
  subcategory String?
  tags        String
  product     String   @default("ALL")   // SALESPERSON | BROKER | CAM | ALL
  difficulty  String   @default("BEGINNER")
  isPublished Boolean  @default(true)
  isInternal  Boolean  @default(false)
  views       Int      @default(0)
  helpful     Int      @default(0)
  notHelpful  Int      @default(0)
  flagCount   Int      @default(0)
  lastFlagged DateTime?
  confidence  Int      @default(100)
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User? @relation(fields: [authorId], references: [id])

  @@index([category])
  @@index([isPublished])
  @@map("kb_articles")
}

// ─── Training ─────────────────────────────────────────────────────────────────

model TrainingSession {
  id           String   @id @default(cuid())
  studentId    String
  scenarioId   String
  scenarioName String
  difficulty   String
  status       String   @default("IN_PROGRESS")
  messages     String
  score        Int?
  scoreDetails String?
  feedback     String?
  duration     Int?
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  student User @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("training_sessions")
}

// ─── QA Scoring ──────────────────────────────────────────────────────────────

model QAScore {
  id               String   @id @default(cuid())
  testId           String   @unique
  studentId        String
  knowledgeScore   Int
  applicationScore Int
  accuracyScore    Int
  efficiencyScore  Int
  completionScore  Int
  totalScore       Int
  feedback         String?
  reviewedBy       String?
  createdAt        DateTime @default(now())

  test    PracticeTest @relation(fields: [testId], references: [id])
  student User         @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("qa_scores")
}

// ─── Classroom ───────────────────────────────────────────────────────────────

model ClassroomProgress {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  moduleId    String
  completed   Boolean   @default(false)
  labScore    Int?
  xpEarned    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, moduleId])
  @@index([userId])
  @@map("classroom_progress")
}

model ClassroomCertificate {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  courseName String
  certNumber String   @unique @default(cuid())
  issuedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@map("classroom_certificates")
}

model ClassroomBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("classroom_badges")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

// ─── Breakroom ────────────────────────────────────────────────────────────────

model BreakroomMessage {
  id        String   @id @default(cuid())
  userId    String
  content   String
  channel   String   @default("general")
  msgType   String   @default("TEXT")
  replyToId String?
  createdAt DateTime @default(now())

  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo   BreakroomMessage?    @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   BreakroomMessage[]   @relation("MessageReplies")
  reactions BreakroomReaction[]

  @@index([channel, createdAt])
  @@map("breakroom_messages")
}

model BreakroomReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message BreakroomMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("breakroom_reactions")
}

model BreakroomPresence {
  id              String   @id @default(cuid())
  userId          String   @unique
  inVoiceChannel  String?
  isMuted         Boolean  @default(false)
  isDeafened      Boolean  @default(false)
  isSpeaking      Boolean  @default(false)
  typingInChannel String?
  typingAt        DateTime?
  lastSeen        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("breakroom_presence")
}

model BreakroomChannel {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String   @default("TEXT")
  position  Int      @default(0)
  createdAt DateTime @default(now())
  createdBy String?
  unreads   BreakroomUnread[]

  @@map("breakroom_channels")
}

model BreakroomUnread {
  id         String   @id @default(cuid())
  userId     String
  channelId  String
  count      Int      @default(0)
  hasMention Boolean  @default(false)
  lastRead   DateTime @default(now())

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel BreakroomChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId])
  @@map("breakroom_unreads")
}

model BreakroomSignal {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  type      String
  payload   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([toId, read])
  @@index([createdAt])
  @@map("breakroom_signals")
}

// ─── Tokens & Presence ───────────────────────────────────────────────────────

model TokenTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("token_transactions")
}

model UserPresence {
  userId   String   @id
  lastSeen DateTime @default(now())
  status   String   @default("online")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_presence")
}

// ─── Obsidian Knowledge Brain ────────────────────────────────────────────────

model ObsidianNote {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String
  folder     String   @default("GA Real Estate")
  category   String   @default("General")
  tags       String   @default("[]")
  isPinned   Boolean  @default(false)
  isDaily    Boolean  @default(false)
  isTemplate Boolean  @default(false)
  wordCount  Int      @default(0)
  aiSummary  String?
  metadata   String   @default("{}")
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  incomingLinks ObsidianLink[] @relation("TargetNote")
  outgoingLinks ObsidianLink[] @relation("SourceNote")

  @@index([category])
  @@index([authorId])
  @@map("obsidian_notes")
}

model ObsidianLink {
  id        String       @id @default(cuid())
  sourceId  String
  targetId  String
  context   String?
  source    ObsidianNote @relation("SourceNote", fields: [sourceId], references: [id], onDelete: Cascade)
  target    ObsidianNote @relation("TargetNote", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([sourceId, targetId])
  @@map("obsidian_links")
}

// ─── System ──────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}
